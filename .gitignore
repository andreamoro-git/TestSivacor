# Stata logs
*.log

# macOS
.DS_Store

# Confidential data: never commit (also excluded from the sivacor output
# via .sivacorignore)
/data/raw-confidential/*.dta

# Other data and generated outputs (rebuildable: run make_data.do, then main.do)
/data/raw/*.dta
/data/derived/*.dta
/output/tables/*.txt
/output/figures/*.png

# Downloaded sivacor output (not part of the package)
Output_From_Sivacor*
